# ==============================================================================
# Environment variables — [PROJECT_NAME]
# ==============================================================================
# Copy this file to `.env` and fill in the values for your environment.
#   cp .env.example .env
#
# NEVER commit your `.env` file with real values to the repository.
# See SECURITY.md and docs/conventions/secrets.md.
# ==============================================================================

# ── Environment ─────────────────────────────────────────────────────────────
# Runtime environment: development | staging | production
APP_ENV=development
# Port the application listens on
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────
# Connection string for the main database
DATABASE_URL=

# ── Authentication ──────────────────────────────────────────────────────────
# Secret for signing tokens/sessions (generate a long random one)
AUTH_SECRET=
# Token expiration time
AUTH_TOKEN_TTL=7d

# ── APIs / external services ────────────────────────────────────────────────
# Key and URL for the external service [SERVICE/API]
API_KEY=
API_URL=

# ── Logging ─────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── [OTHER_VARIABLES] ─────────────────────────────────────────────────────
